# Required
ANTHROPIC_API_KEY=sk-ant-...

# Subscription keys (comma-separated — give one per user)
SUBSCRIPTION_KEYS=sk-sub-abc123,sk-sub-def456

# CORS — set to your deployed frontend domain
ALLOWED_ORIGINS=https://yourdomain.com

# Port (default 3000)
PORT=3000

# Optional: web search for live prospect/competitor research
# Get a key from serper.dev (cheaper) or serpapi.com
SEARCH_API_KEY=
SEARCH_PROVIDER=serper

# Optional: admin endpoint for generating new subscription keys
ADMIN_SECRET=your-admin-secret-here
